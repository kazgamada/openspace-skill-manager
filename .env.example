# ── Database (必須) ────────────────────────────────────────────────────────────
# Supabase: Settings → Database → Connection string → URI (Pooler port 6543 推奨)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# ── Session (必須) ────────────────────────────────────────────────────────────
# JWT 署名用シークレット（32文字以上のランダム文字列）
# Generate: openssl rand -hex 32
JWT_SECRET=replace-with-a-random-secret-32chars-or-more

# ── Token Encryption ──────────────────────────────────────────────────────────
# 32-byte hex key for AES-256-GCM encryption of stored API tokens
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=replace-with-a-random-32-byte-hex-key

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://yourdomain.com

# ── ログイン (必須) ────────────────────────────────────────────────────────────
# kazgamada@gmail.com は自動的にオーナーとして許可される
# LOCAL_ADMIN_EMAIL は省略可能
LOCAL_ADMIN_PASSWORD=set-your-password-here
# LOCAL_ADMIN_NAME=Admin  # 任意

# ── AI Features (optional) ────────────────────────────────────────────────────
# Forge / Gemini API for skill evolution, AI merge, and benefit headline generation
# BUILT_IN_FORGE_API_URL=https://...
# BUILT_IN_FORGE_API_KEY=...

# ── Manus OAuth (optional — omit to use local login instead) ──────────────────
# OAUTH_SERVER_URL=https://oauth.manus.com
# VITE_APP_ID=your-manus-app-id
# VITE_OAUTH_PORTAL_URL=https://manus.im

# ── X (Twitter) API (optional — enables X mention scoring) ────────────────────
# TWITTER_BEARER_TOKEN=AAAA...

# ── Stripe (optional — enables billing/subscriptions) ─────────────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── Email (optional — enables notifications, verification) ────────────────────
# RESEND_API_KEY=re_...
# FROM_EMAIL=noreply@yourdomain.com

# ── Error Tracking (optional) ─────────────────────────────────────────────────
# SENTRY_DSN=https://...@sentry.io/...

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
