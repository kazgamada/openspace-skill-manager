# ── Database (PostgreSQL) ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/openspace

# ── Session ───────────────────────────────────────────────────────────────────
# Random secret for signing JWT session cookies (min 32 chars)
# Generate: openssl rand -hex 32
JWT_SECRET=replace-with-a-random-secret-min-32-chars

# ── Token Encryption ──────────────────────────────────────────────────────────
# 32-byte hex key for AES-256-GCM encryption of stored API tokens
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=replace-with-a-random-32-byte-hex-key

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://yourdomain.com

# ── Local Auth (used when OAUTH_SERVER_URL is NOT set) ────────────────────────
LOCAL_ADMIN_EMAIL=admin@example.com
LOCAL_ADMIN_PASSWORD=changeme
LOCAL_ADMIN_NAME=Admin

# ── AI Features (optional) ────────────────────────────────────────────────────
# Forge / Gemini API for skill evolution, AI merge, and benefit headline generation
# BUILT_IN_FORGE_API_URL=https://...
# BUILT_IN_FORGE_API_KEY=...

# ── Manus OAuth (optional — omit to use local login instead) ──────────────────
# OAUTH_SERVER_URL=https://oauth.manus.com
# VITE_APP_ID=your-manus-app-id
# VITE_OAUTH_PORTAL_URL=https://manus.im

# ── X (Twitter) API (optional — enables X mention scoring) ────────────────────
# TWITTER_BEARER_TOKEN=AAAA...

# ── Stripe (optional — enables billing/subscriptions) ─────────────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── Email (optional — enables notifications, verification) ────────────────────
# RESEND_API_KEY=re_...
# FROM_EMAIL=noreply@yourdomain.com

# ── Error Tracking (optional) ─────────────────────────────────────────────────
# SENTRY_DSN=https://...@sentry.io/...

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
