# ── Database ──────────────────────────────────────────────────────────────────
# MySQL / TiDB Cloud connection string
DATABASE_URL=mysql://user:password@host:3306/openspace

# ── Session ───────────────────────────────────────────────────────────────────
# Random secret for signing JWT session cookies (openssl rand -hex 32)
JWT_SECRET=replace-with-a-random-secret

# ── Local Auth (used when OAUTH_SERVER_URL is NOT set) ────────────────────────
LOCAL_ADMIN_EMAIL=admin@example.com
LOCAL_ADMIN_PASSWORD=changeme
LOCAL_ADMIN_NAME=Admin

# ── AI Features (optional) ────────────────────────────────────────────────────
# Forge / Gemini API for skill evolution and AI features
# BUILT_IN_FORGE_API_URL=https://...
# BUILT_IN_FORGE_API_KEY=...

# ── Manus OAuth (optional — omit to use local login instead) ──────────────────
# OAUTH_SERVER_URL=https://oauth.manus.com
# VITE_APP_ID=your-manus-app-id
# VITE_OAUTH_PORTAL_URL=https://manus.im

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
