# ── Database (必須) ────────────────────────────────────────────────────────────
# Supabase: Settings → Database → Connection string → URI (Pooler port 6543 推奨)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# ── Session (必須) ────────────────────────────────────────────────────────────
# JWT 署名用シークレット（32文字以上のランダム文字列）
JWT_SECRET=replace-with-a-random-secret-32chars-or-more

# ── ログイン (必須) ────────────────────────────────────────────────────────────
# kazgamada@gmail.com は自動的にオーナーとして許可される
# LOCAL_ADMIN_EMAIL は省略可能
LOCAL_ADMIN_PASSWORD=set-your-password-here
# LOCAL_ADMIN_NAME=Admin  # 任意

# ── AI Features (optional) ────────────────────────────────────────────────────
# Forge / Gemini API for skill evolution and AI features
# BUILT_IN_FORGE_API_URL=https://...
# BUILT_IN_FORGE_API_KEY=...

# ── Manus OAuth (optional — omit to use local login instead) ──────────────────
# OAUTH_SERVER_URL=https://oauth.manus.com
# VITE_APP_ID=your-manus-app-id
# VITE_OAUTH_PORTAL_URL=https://manus.im

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
